{
  "name": "figmatk",
  "version": "0.0.12",
  "description": "Figma Toolkit — Swiss-army knife CLI for Figma .deck and .fig files",
  "type": "module",
  "bin": {
    "figmatk": "cli.mjs",
    "figmatk-mcp": "mcp-server.mjs"
  },
  "exports": {
    ".": "./lib/api.mjs",
    "./deck": "./lib/fig-deck.mjs",
    "./node-helpers": "./lib/node-helpers.mjs",
    "./image-helpers": "./lib/image-helpers.mjs",
    "./deep-clone": "./lib/deep-clone.mjs"
  },
  "files": [
    "cli.mjs",
    "mcp-server.mjs",
    "lib/",
    "commands/",
    "skills/",
    ".claude-plugin/",
    ".mcp.json",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "start": "node cli.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rcoenen/figmatk.git"
  },
  "homepage": "https://github.com/rcoenen/figmatk",
  "bugs": {
    "url": "https://github.com/rcoenen/figmatk/issues"
  },
  "author": "rcoenen",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "archiver": "^7.0.1",
    "fzstd": "^0.1.1",
    "kiwi-schema": "^0.5.0",
    "pako": "^2.1.0",
    "sharp": "^0.34.5",
    "zstd-codec": "^0.1.5"
  },
  "keywords": [
    "figma",
    "deck",
    "fig",
    "slides",
    "presentation",
    "kiwi",
    "binary",
    "cli"
  ],
  "license": "MIT"
}
